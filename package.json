{
  "name": "kendex",
  "version": "0.3.5",
  "description": "Kendex - local file indexer desktop app",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "smoke": "FILE_INDEXER_ELECTRON_SMOKE=1 electron .",
    "check": "node --check electron/main.js && python3 -m py_compile crawler.py query_app.py compact_db.py",
    "dist": "electron-builder --mac dmg zip"
  },
  "build": {
    "appId": "com.kendex.desktop",
    "productName": "Kendex",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "afterSign": "scripts/notarize.js",
    "asar": true,
    "publish": {
      "provider": "github",
      "owner": "KMSarno",
      "repo": "file-indexer"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "crawler.py",
        "to": "backend/crawler.py"
      },
      {
        "from": "query_app.py",
        "to": "backend/query_app.py"
      },
      {
        "from": "compact_db.py",
        "to": "backend/compact_db.py"
      },
      {
        "from": "pyproject.toml",
        "to": "backend/pyproject.toml"
      },
      {
        "from": "uv.lock",
        "to": "backend/uv.lock"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  }
}
